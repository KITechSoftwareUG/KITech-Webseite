# Plausible Analytics (self-hosted)
# Konfiguration ist jetzt hardcoded in src/lib/plausible.ts und CookieConsent.tsx
# Diese Env-Vars werden NICHT mehr verwendet, bleiben aber als Referenz:
# VITE_PLAUSIBLE_DOMAIN=kitech-software.de
# VITE_PLAUSIBLE_SRC=https://stats.kitech-software.de/js/script.js
# VITE_PLAUSIBLE_API_HOST=https://stats.kitech-software.de/api/event

# Kontaktformular Webhook (n8n oder anderer Service)
VITE_CONTACT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/contact-form
